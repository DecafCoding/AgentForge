# =============================================================================
# AgentForge — Production Environment
# Copy to .env and fill in values before deploying.
# =============================================================================

# -----------------------------------------------------------------------------
# Domain (Phase 6)
# Required for automatic HTTPS via Caddy + Let's Encrypt.
# Set to a real domain (e.g., agents.example.com) for HTTPS.
# Use "localhost" for local testing — Caddy will serve without HTTPS.
# -----------------------------------------------------------------------------
DOMAIN=agents.example.com

# -----------------------------------------------------------------------------
# LLM Provider
# Supported values for MODEL_PROVIDER: openai | groq | ollama
# MODEL_NAME must be a valid model name for the selected provider.
# -----------------------------------------------------------------------------
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o

OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk-...

# -----------------------------------------------------------------------------
# Database
# Point to your shared Postgres instance.
# Use the Docker service name (supabase-db) when running bundled.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://agentforge:STRONG_PASSWORD@supabase-db:5432/agentforge

# -----------------------------------------------------------------------------
# Langfuse (Observability)
# Point to your shared Langfuse instance.
# Use the Docker service name (langfuse-server) when running bundled.
# Get your keys from the Langfuse dashboard.
# -----------------------------------------------------------------------------
LANGFUSE_HOST=http://langfuse-server:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# -----------------------------------------------------------------------------
# CORS (Phase 6)
# Set to your production domain. Comma-separate multiple origins if needed.
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://agents.example.com

# -----------------------------------------------------------------------------
# Frontend (Phase 6)
# VITE_API_BASE: API base path. Default "/api" works with Caddy proxy.
# -----------------------------------------------------------------------------
VITE_API_BASE=/api

# -----------------------------------------------------------------------------
# YouTube Collector
# YOUTUBE_API_KEY: Google Cloud API key with YouTube Data API v3 enabled.
# COLLECTION_INTERVAL_MINUTES: How often the collector runs (default: 60).
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=AIza...
COLLECTION_INTERVAL_MINUTES=60

# -----------------------------------------------------------------------------
# Memory (Phase 3)
# MEMORY_MODEL: Low-cost model recommended for memory extraction.
# -----------------------------------------------------------------------------
MEMORY_ENABLED=true
MEMORY_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Web Scraping (Phase 3)
# Comma-separated URLs. Leave empty to disable.
# -----------------------------------------------------------------------------
SCRAPE_URLS=
SCRAPE_INTERVAL_MINUTES=360

# -----------------------------------------------------------------------------
# Web Search (Phase 3)
# -----------------------------------------------------------------------------
BRAVE_SEARCH_API_KEY=BSA-...
BRAVE_SEARCH_ENABLED=true

# -----------------------------------------------------------------------------
# Search Provider (Phase 4)
# brave: Requires BRAVE_SEARCH_API_KEY.
# searxng: Requires SearXNG running (--profile local-ai).
# -----------------------------------------------------------------------------
SEARCH_PROVIDER=brave
SEARXNG_HOST=http://searxng:8080

# -----------------------------------------------------------------------------
# Ollama — Local LLM Serving (Phase 4)
# Only needed if MODEL_PROVIDER=ollama.
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://ollama:11434

# -----------------------------------------------------------------------------
# Caching (Phase 4)
# Only enable after identifying a specific measured bottleneck.
# -----------------------------------------------------------------------------
CACHE_ENABLED=false
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Evaluation (Phase 5)
# -----------------------------------------------------------------------------
EVAL_MODEL=gpt-4o
EVAL_DATASET_LIMIT=100

# -----------------------------------------------------------------------------
# MCP Server (Phase 5)
# -----------------------------------------------------------------------------
MCP_TRANSPORT=stdio
MCP_PORT=8001
