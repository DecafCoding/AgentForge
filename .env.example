# =============================================================================
# AgentForge — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider
# Supported values for MODEL_PROVIDER: openai | groq
# MODEL_NAME must be a valid model name for the selected provider.
# -----------------------------------------------------------------------------
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o

OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk-...

# -----------------------------------------------------------------------------
# Database
# Defaults point to the bundled Docker Compose Postgres service.
# Override with your shared server connection string when not using --profile bundled.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentforge

# -----------------------------------------------------------------------------
# Langfuse (Observability)
# Defaults point to the bundled Docker Compose Langfuse service.
# Override with your shared Langfuse instance when not using --profile bundled.
# Get your keys from the Langfuse dashboard after first run.
# -----------------------------------------------------------------------------
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# -----------------------------------------------------------------------------
# YouTube Collector
# YOUTUBE_API_KEY: Google Cloud API key with YouTube Data API v3 enabled.
# COLLECTION_INTERVAL_MINUTES: How often the collector runs (default: 60).
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=AIza...
COLLECTION_INTERVAL_MINUTES=60
